# ─── Supercell Official API ───────────────────────────────────────────────────
# Get your token at https://developer.clashofclans.com
# Sign up with any email — separate from your game Supercell ID.
# Tokens are IP-LOCKED — register the public IP of the machine running the bot.
COC_API_TOKEN=your_api_token_here

# ─── Your Account ─────────────────────────────────────────────────────────────
# Player tag of the account being controlled (with or without #)
PLAYER_TAG=#ABC123XYZ

# ─── ADB / Android Emulator ───────────────────────────────────────────────────
# MuMu Player 12:  ADB_HOST=127.0.0.1  ADB_PORT=16384
# LDPlayer 9:      ADB_HOST=127.0.0.1  ADB_PORT=5555
# Android SDK AVD: ADB_HOST=127.0.0.1  ADB_PORT=5554
# BlueStacks 5:    ADB_HOST=127.0.0.1  ADB_PORT=5556
ADB_HOST=127.0.0.1
ADB_PORT=16384

# Screen resolution — must match your emulator window size.
# Set emulator to 1920x1080 (landscape), 240 dpi.
EMULATOR_WIDTH=1920
EMULATOR_HEIGHT=1080

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
# Bot → Token → Reset Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Right-click your server name in Discord → Copy Server ID
# (Enable Developer Mode in Discord Settings → Advanced first)
DISCORD_GUILD_ID=your_guild_id_here

# Optional: webhook for kick reports (create in Server Settings → Integrations)
DISCORD_KICK_WEBHOOK=
