# ─── Supercell Official API ───────────────────────────────────────────────────
# Get your token at https://developer.clashofclans.com
# Sign up with any email/password — separate from your game Supercell ID.
# Tokens are IP-locked — register the IP of your server.
COC_API_TOKEN=your_api_token_here

# ─── Your Account / Clan ──────────────────────────────────────────────────────
# Player tag of the account being controlled (with or without #)
PLAYER_TAG=#ABC123XYZ

# Clan tag to monitor (optional)
CLAN_TAG=#CLANTAGXYZ

# ─── ADB / Android Emulator ───────────────────────────────────────────────────
# Host and port where ADB is exposed
# If running docker-android locally: localhost:5555
# If emulator is remote: your-server-ip:5555
ADB_HOST=localhost
ADB_PORT=5555

# Android device serial override (leave blank to auto-detect)
ADB_DEVICE_SERIAL=

# Screen resolution of the emulator (must match what you configure in docker-android)
EMULATOR_WIDTH=1080
EMULATOR_HEIGHT=1920

# ─── Bot Behaviour ────────────────────────────────────────────────────────────
# Tasks to run: recruit, war  (comma-separated)
BOT_TASKS=recruit

# ─── Anti-Ban / Humanisation ─────────────────────────────────────────────────
# Add random human-like delays between actions (seconds)
MIN_ACTION_DELAY=0.3
MAX_ACTION_DELAY=1.2

# Random break every N cycles (0 = disabled)
BREAK_EVERY_N_CYCLES=10
BREAK_DURATION_MIN=300
BREAK_DURATION_MAX=900

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/cocbot.log

# ─── Optional: AI Base Analysis (Gemini Vision) ───────────────────────────────
# GEMINI_API_KEY=your_gemini_key_here

# ─── Recruit / Auto-Invite ────────────────────────────────────────────────────
# In-game board filter: only show players in this TH range
RECRUIT_MIN_TH=10
RECRUIT_MAX_TH=17

# API filters: only invite players who meet ALL of these
RECRUIT_MIN_DONATIONS=500        # Minimum donations this season
RECRUIT_MIN_TROPHIES=1500        # Minimum current trophies
RECRUIT_MIN_WAR_STARS=100        # Minimum all-time war stars
RECRUIT_MIN_ATTACK_WINS=500      # Minimum attack wins (measures activity)
# RECRUIT_REQUIRED_LEAGUE=Gold League I   # Uncomment to require a specific league

# How many invites to send per run
RECRUIT_MAX_INVITES_PER_RUN=20

# Seconds between recruit runs (default: 1 hour)
RECRUIT_CYCLE_INTERVAL=3600
